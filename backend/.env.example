# Template for standalone (non-Docker) backend dev — copy to backend/.env.
# The full monorepo template (used by docker-compose) lives at ../.env.example.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Service-role key — backend ONLY, never expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection, for the LangGraph checkpointer (optional).
SUPABASE_DB_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Google Gemini (for LangGraph agents)
GOOGLE_API_KEY=your-google-api-key
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite

# Pinecone (vector DB + integrated embedding for Legal Agent RAG)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=astalink-regulations

# News API (optional — market agent runs without it)
NEWS_API_KEY=

# Resend (transactional email — signup confirmation, password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@astalink.my.id

# WhatsApp Business API (Meta Cloud API, optional)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
APP_BASE_URL=http://localhost:3000

BACKEND_CORS_ORIGINS=["http://localhost:3000"]
