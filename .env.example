# Supabase (shared between frontend and backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
# Service-role key — backend ONLY, never expose to frontend.
# Used for admin writes that bypass RLS (audit_log, regulation_documents).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Khusus untuk drizzle-kit push
DATABASE_URL=

# Google Gemini (for LangGraph agents)
GOOGLE_API_KEY=your-google-api-key
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite

# Pinecone (vector DB + integrated embedding for Legal Agent RAG)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=astalink-regulations

# Backend
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000  # Dev only; prod uses /api via reverse proxy

# Production
PROD_DOMAIN=https://yourdomain.com
# Bare hostname (no scheme) used by Traefik label rules in docker-compose.prod.yml.
PROD_DOMAIN_HOST=yourdomain.com
GRAFANA_ADMIN_PASSWORD=change-me

# Supabase Postgres direct connection (for LangGraph checkpointer)
# Get from Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# News API (optional — market agent runs without it)
NEWS_API_KEY=

# Resend (transactional email — signup confirmation, password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@astalink.my.id

# Admin role — emails in this list get admin-only access (e.g. Legal Docs).
# JSON array of strings.
ADMIN_EMAILS=["admin@example.com"]

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
APP_BASE_URL=http://localhost:3000
